{
  "manifest_version": 3,
  "name": "TransFlash Live Translate",
  "version": "0.12.7",
  "description": "Real-time translation subtitles for meetings & videos (Google Meet, Zoom, Teams, YouTube) — or in-person via your microphone.",
  "permissions": ["tabCapture", "offscreen", "scripting", "activeTab", "storage", "identity"],
  "host_permissions": ["https://meet.transflash.app/*"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Live Translate",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "web_accessible_resources": [
    { "resources": ["icons/icon16.png", "icons/icon48.png", "icons/icon128.png"], "matches": ["<all_urls>"] }
  ]
}
