# ============================================================
#  Meeting AI — environment variables
#  Copy this file to ".env.local" and fill in the values.
#  NEVER commit .env.local to git.
# ============================================================

# --- AI providers (server-side only, kept secret) ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx
ASSEMBLYAI_API_KEY=xxxxxxxxxxxxxxxx

# --- Supabase (Phase 2) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxx

# --- Lemon Squeezy (Phase 4) ---
LEMONSQUEEZY_API_KEY=xxxxxxxx
LEMONSQUEEZY_STORE_ID=xxxxx
LEMONSQUEEZY_WEBHOOK_SECRET=xxxxxxxx
NEXT_PUBLIC_LEMONSQUEEZY_VARIANT_ID=xxxxx   # the subscription plan's variant id

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
