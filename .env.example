# ============================================================
#  Meeting AI — environment variables
#  Copy this file to ".env.local" and fill in the values.
#  NEVER commit .env.local to git.
# ============================================================

# --- AI providers (server-side only, kept secret) ---
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxx
# Soniox — real-time STT + live translation, and async file transcription
SONIOX_API_KEY=xxxxxxxxxxxxxxxx
# AssemblyAI — no longer used (replaced by Soniox), kept for reference
ASSEMBLYAI_API_KEY=xxxxxxxxxxxxxxxx

# --- Supabase (auth + profiles) — required for Google login ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxx

# --- Lemon Squeezy (subscriptions) — Phase 2 ---
LEMONSQUEEZY_API_KEY=xxxxxxxx
LEMONSQUEEZY_STORE_ID=xxxxx
LEMONSQUEEZY_WEBHOOK_SECRET=xxxxxxxx
LEMONSQUEEZY_VARIANT_PRO=xxxxx        # variant id of the Pro plan
LEMONSQUEEZY_VARIANT_BUSINESS=xxxxx   # variant id of the Business plan

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
